<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Password Changed — LinkForge</title>
    <style>
      @media only screen and (max-width: 600px) {
        .email-wrapper {
          padding: 16px 8px !important;
        }
        .email-card {
          width: 100% !important;
          border-radius: 14px !important;
        }
        .card-header {
          padding: 18px 20px !important;
        }
        .card-body {
          padding: 24px 20px !important;
        }
        .card-footer {
          padding: 14px 20px !important;
        }
        .header-title {
          font-size: 17px !important;
        }
        .logo-img {
          width: 100px !important;
        }
        .icon-box {
          width: 36px !important;
          height: 36px !important;
          line-height: 36px !important;
          font-size: 16px !important;
        }
        .notice-box {
          padding: 12px 14px !important;
        }
        .greeting {
          font-size: 18px !important;
        }
        .detail-box {
          padding: 14px 16px !important;
        }
      }
    </style>
  </head>
  <body style="margin:0;padding:0;background-color:#f6f8fa;font-family:Arial,sans-serif;">

    <div style="display:none;max-height:0;overflow:hidden;opacity:0;">
      Your LinkForge password was changed successfully.
    </div>

    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center" style="padding:40px 16px;" class="email-wrapper">
          <table width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:560px;" class="email-card">

            <tr>
              <td style="background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;box-shadow:0 2px 12px rgba(0,0,0,0.06);">

                <!-- HEADER — gray. -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="background:#1e293b;padding:24px 28px 22px;" class="card-header">
                      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:16px;">
                        <tr>
                          <td align="center">
                            <img
                              src="https://res.cloudinary.com/bishal101/image/upload/e_background_removal/LinkForge_jwecgh.png"
                              alt="LinkForge"
                              width="120"
                              class="logo-img"
                              style="display:block;margin:0 auto;"
                            />
                          </td>
                        </tr>
                      </table>
                      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:16px;">
                        <tr><td style="height:1px;background:rgba(255,255,255,0.15);"></td></tr>
                      </table>
                      <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td valign="middle" style="vertical-align:middle;">
                            <p style="margin:0 0 3px 0;font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.6);">Account Security</p>
                            <p style="margin:0;font-size:20px;font-weight:700;color:#ffffff;letter-spacing:-0.3px;" class="header-title">Password changed</p>
                          </td>
                          <td width="48" style="vertical-align:middle;padding-left:12px;white-space:nowrap;" valign="middle" align="right">
                            <div
                              style="width:40px;height:40px;background:rgba(255,255,255,0.18);border-radius:10px;text-align:center;line-height:40px;font-size:18px;"
                              class="icon-box"
                            >🔒</div>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- BODY -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="padding:28px 32px;" class="card-body">
                      <p style="margin:0 0 6px 0;font-size:20px;font-weight:700;color:#111827;" class="greeting">Hi {{name}},</p>
                      <p style="margin:0 0 24px 0;font-size:15px;color:#6b7280;line-height:1.7;">Your LinkForge account password was changed successfully. This is a confirmation of that
                        activity.</p>

                      <!-- DETAIL BOX -->
                      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:20px;">
                        <tr>
                          <td style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:10px;padding:16px 18px;" class="detail-box">
                            <table width="100%" cellpadding="0" cellspacing="0" border="0">
                              <tr>
                                <td style="padding:5px 0;border-bottom:1px solid #f3f4f6;">
                                  <span style="font-size:13px;color:#9ca3af;">Action</span>
                                  <span style="float:right;font-size:13px;font-weight:600;color:#111827;">Password changed</span>
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>
                      </table>

                      <!-- ALERT — red only for the "wasn't you" warning, not the whole email -->
                      <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td style="background:#fef2f2;border-left:3px solid #ef4444;border-radius:0 8px 8px 0;padding:13px 15px;" class="notice-box">
                            <p style="margin:0;font-size:14px;color:#374151;line-height:1.6;">
                              <strong style="color:#991b1b;">Wasn't you?</strong>
                              Reset your password immediately and contact
                              <a href="mailto:support@linkforge.com" style="color:#5b6dff;text-decoration:none;font-weight:600;">support@linkforge.com</a>.
                            </p>
                          </td>
                        </tr>
                      </table>

                      <p style="margin:20px 0 0 0;font-size:13px;color:#9ca3af;line-height:1.6;">
                        This notification confirms account activity and keeps your account secure.
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- FOOTER -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr><td style="padding:0 32px;"><div style="height:1px;background:#f3f4f6;"></div></td></tr>
                  <tr>
                    <td align="center" style="padding:16px 32px;" class="card-footer">
                      <p style="margin:0;font-size:12px;color:#9ca3af;">© 2026 LinkForge. All rights reserved.</p>
                    </td>
                  </tr>
                </table>

              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>