<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to LinkForge</title>
    <style>
      @media only screen and (max-width: 600px) {
        .email-wrapper {
          padding: 16px 8px !important;
        }
        .email-card {
          width: 100% !important;
          border-radius: 14px !important;
        }
        .card-header {
          padding: 18px 20px !important;
        }
        .card-body {
          padding: 24px 20px !important;
        }
        .card-footer {
          padding: 14px 20px !important;
        }
        .header-title {
          font-size: 17px !important;
        }
        .logo-img {
          width: 100px !important;
        }
        .cta-btn {
          padding: 13px 24px !important;
          font-size: 14px !important;
        }
        .icon-box {
          width: 36px !important;
          height: 36px !important;
          line-height: 36px !important;
          font-size: 16px !important;
        }
        .notice-box {
          padding: 12px 14px !important;
        }
        .greeting {
          font-size: 18px !important;
        }
        .feature-cell {
          display: block !important;
          width: 100% !important;
          padding: 4px 0 !important;
        }
      }
    </style>
  </head>
  <body style="margin:0;padding:0;background-color:#f6f8fa;font-family:Arial,sans-serif;">

    <div style="display:none;max-height:0;overflow:hidden;opacity:0;">
      Your LinkForge account is verified and ready to use.
    </div>

    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center" style="padding:40px 16px;" class="email-wrapper">
          <table width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:560px;" class="email-card">

            <tr>
              <td style="background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;box-shadow:0 2px 12px rgba(0,0,0,0.06);">

                <!-- HEADER -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="background:#10b981;padding:24px 28px 22px;" class="card-header">
                      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:16px;">
                        <tr>
                          <td align="center">
                            <img
                              src="https://res.cloudinary.com/bishal101/image/upload/e_background_removal/LinkForge_jwecgh.png"
                              alt="LinkForge"
                              width="120"
                              class="logo-img"
                              style="display:block;margin:0 auto;"
                            />
                          </td>
                        </tr>
                      </table>
                      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:16px;">
                        <tr><td style="height:1px;background:rgba(255,255,255,0.15);"></td></tr>
                      </table>
                      <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td valign="middle" style="vertical-align:middle;">
                            <p style="margin:0 0 3px 0;font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.6);">Account Verified</p>
                            <p style="margin:0;font-size:20px;font-weight:700;color:#ffffff;letter-spacing:-0.3px;" class="header-title">You're in. Welcome aboard.</p>
                          </td>
                          <td width="48" style="vertical-align:middle;padding-left:12px;white-space:nowrap;" valign="middle" align="right">
                            <div
                              style="width:40px;height:40px;background:rgba(255,255,255,0.18);border-radius:10px;text-align:center;line-height:40px;font-size:18px;"
                              class="icon-box"
                            >✅</div>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- BODY -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="padding:28px 32px;" class="card-body">
                      <p style="margin:0 0 6px 0;font-size:20px;font-weight:700;color:#111827;" class="greeting">Welcome, {{name}}!</p>
                      <p style="margin:0 0 24px 0;font-size:15px;color:#6b7280;line-height:1.7;">Your account is now active. Start shortening links, generating QR codes, and tracking every
                        click.</p>

                      <!-- FEATURE PILLS -->
                      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
                        <tr>
                          <td width="33%" style="padding:0 4px 0 0;" class="feature-cell">
                            <div style="background:#f5f3ff;border:1px solid #ddd6fe;border-radius:10px;padding:12px 8px;text-align:center;">
                              <p style="margin:0 0 3px 0;font-size:16px;">🔗</p>
                              <p style="margin:0;font-size:12px;font-weight:600;color:#5b21b6;">Short Links</p>
                            </div>
                          </td>
                          <td width="33%" style="padding:0 2px;" class="feature-cell">
                            <div style="background:#ecfeff;border:1px solid #a5f3fc;border-radius:10px;padding:12px 8px;text-align:center;">
                              <p style="margin:0 0 3px 0;font-size:16px;">📊</p>
                              <p style="margin:0;font-size:12px;font-weight:600;color:#0e7490;">Analytics</p>
                            </div>
                          </td>
                          <td width="33%" style="padding:0 0 0 4px;" class="feature-cell">
                            <div style="background:#faf5ff;border:1px solid #e9d5ff;border-radius:10px;padding:12px 8px;text-align:center;">
                              <p style="margin:0 0 3px 0;font-size:16px;">⬛</p>
                              <p style="margin:0;font-size:12px;font-weight:600;color:#7c3aed;">QR Codes</p>
                            </div>
                          </td>
                        </tr>
                      </table>

                      <table cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px 0;">
                        <tr>
                          <td>
                            <a
                              href="{{loginLink}}"
                              style="display:inline-block;background:#5b6dff;color:#ffffff;text-decoration:none;padding:14px 32px;border-radius:10px;font-size:15px;font-weight:700;box-shadow:0 4px 14px rgba(91,109,255,0.3);"
                              class="cta-btn"
                            >Sign In →</a>
                          </td>
                        </tr>
                      </table>

                      <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td style="background:#f0fdf4;border-left:3px solid #10b981;border-radius:0 8px 8px 0;padding:13px 15px;" class="notice-box">
                            <p style="margin:0;font-size:14px;color:#374151;line-height:1.6;">
                              <strong style="color:#065f46;">Account active:</strong>
                              Fully verified and ready to use. No further action needed.
                            </p>
                          </td>
                        </tr>
                      </table>

                      <p style="margin:20px 0 0 0;font-size:13px;color:#9ca3af;">Thank you for joining LinkForge.</p>
                    </td>
                  </tr>
                </table>

                <!-- FOOTER -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr><td style="padding:0 32px;"><div style="height:1px;background:#f3f4f6;"></div></td></tr>
                  <tr>
                    <td align="center" style="padding:16px 32px;" class="card-footer">
                      <p style="margin:0;font-size:12px;color:#9ca3af;">© 2026 LinkForge. All rights reserved.</p>
                    </td>
                  </tr>
                </table>

              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>