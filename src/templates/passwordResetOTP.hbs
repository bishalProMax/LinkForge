<html lang="en">

  <head>

    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>
      Password Reset OTP
    </title>

  </head>

  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f4f7fb;
      font-family: Arial, sans-serif;
    "
  >

    <!-- PREHEADER -->

    <div
      style="
        display: none;
        max-height: 0;
        overflow: hidden;
        opacity: 0;
      "
    >
      Your LinkForge password reset OTP is inside.
    </div>

    <table width="100%" cellpadding="0" cellspacing="0" border="0">

      <tr>

        <td
          align="center"
          style="
            padding: 32px 16px;
          "
        >

          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            border="0"
            style="
              background: #ffffff;
              border-radius: 18px;
              overflow: hidden;

              box-shadow:
                0 10px 30px rgba(0,0,0,0.08);
            "
          >

            <!-- HEADER -->

            <tr>

              <td
                align="center"
                style="
                  background:
                  linear-gradient(
                    135deg,
                    #667eea,
                    #764ba2
                  );

                  padding: 22px 20px;
                "
              >

                <img
                  src="https://res.cloudinary.com/bishal101/image/upload/LinkForge_jwecgh.png"
                  alt="LinkForge Logo"
                  width="140"
                  style="
                    display: block;
                    margin: 0 auto 12px auto;
                    border-radius: 12px;
                  "
                />

                <p
                  style="
                    margin: 0;
                    color: #f3f4f6;
                    font-size: 20px;
                    font-weight: 600;
                    letter-spacing: 0.3px;
                  "
                >
                  Reset Your Password
                </p>

              </td>

            </tr>

            <!-- BODY -->

            <tr>

              <td
                style="
                  padding: 42px 36px;
                  color: #374151;
                  line-height: 1.8;
                  font-size: 16px;
                "
              >

                <p
                  style="
                    margin-top: 0;
                    margin-bottom: 20px;
                    font-size: 24px;
                    font-weight: 700;
                    color: #111827;
                  "
                >
                  Hi
                  {{name}},
                </p>

                <p
                  style="
                    margin-bottom: 18px;
                  "
                >
                  We received a request to reset your LinkForge account password.
                </p>

                <p
                  style="
                    margin-bottom: 20px;
                  "
                >
                  Use the OTP below to continue:
                </p>

                <!-- OTP BOX -->

                <div
                  style="
                    margin: 26px 0 32px 0;
                    text-align: center;
                  "
                >

                  <span
                    style="
                      display: inline-block;
                      background:
                        linear-gradient(
                          135deg,
                          #667eea,
                          #5a67d8
                        );

                      color: #ffffff;

                      padding: 18px 42px;

                      border-radius: 14px;

                      font-size: 34px;

                      font-weight: 700;

                      letter-spacing: 12px;

                      box-shadow:
                        0 8px 20px rgba(102,126,234,0.28);
                    "
                  >
                    {{otp}}
                  </span>

                </div>

                <!-- SECURITY NOTE -->

                <div
                  style="
                    background: #f9fafb;
                    border-left: 4px solid #667eea;
                    padding: 16px 18px;
                    border-radius: 10px;
                    margin: 28px 0;
                    color: #374151;
                    font-size: 15px;
                  "
                >

                  <strong>
                    Security Notice:
                  </strong>

                  This OTP will expire in
                  <strong>5 minutes</strong>. Never share this code with anyone.

                </div>

                <p
                  style="
                    margin-bottom: 0;
                    color: #6b7280;
                    font-size: 14px;
                  "
                >
                  If you did not request a password reset, you can safely ignore this email.
                </p>

              </td>

            </tr>

            <!-- FOOTER -->

            <tr>

              <td
                align="center"
                style="
                  padding: 22px;
                  background: #f9fafb;
                  color: #9ca3af;
                  font-size: 13px;
                "
              >

                © 2026 LinkForge. All rights reserved.

              </td>

            </tr>

          </table>

        </td>

      </tr>

    </table>

  </body>

</html>
