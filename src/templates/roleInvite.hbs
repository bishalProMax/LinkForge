<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>You're Invited — LinkForge</title>
    <style>
      @media only screen and (max-width: 600px) {
        .email-wrapper {
          padding: 16px 8px !important;
        }
        .email-card {
          width: 100% !important;
          border-radius: 14px !important;
        }
        .card-header {
          padding: 18px 20px !important;
        }
        .card-body {
          padding: 24px 20px !important;
        }
        .card-footer {
          padding: 14px 20px !important;
        }
        .header-title {
          font-size: 17px !important;
        }
        .logo-img {
          width: 100px !important;
        }
        .cta-btn {
          padding: 13px 24px !important;
          font-size: 14px !important;
        }
        .icon-box {
          width: 36px !important;
          height: 36px !important;
          line-height: 36px !important;
          font-size: 16px !important;
        }
        .notice-box {
          padding: 12px 14px !important;
        }
        .greeting {
          font-size: 18px !important;
        }
      }
    </style>
  </head>
  <body style="margin:0;padding:0;background-color:#f6f8fa;font-family:Arial,sans-serif;">

    <div style="display:none;max-height:0;overflow:hidden;opacity:0;">
      You've been invited to join LinkForge with elevated access.
    </div>

    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center" style="padding:40px 16px;" class="email-wrapper">
          <table width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:560px;" class="email-card">

            <tr>
              <td style="background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;box-shadow:0 2px 12px rgba(0,0,0,0.06);">

                <!-- HEADER -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="background:#7c3aed;padding:24px 28px 22px;" class="card-header">
                      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:16px;">
                        <tr>
                          <td align="center">
                            <img
                              src="https://res.cloudinary.com/bishal101/image/upload/e_background_removal/LinkForge_jwecgh.png"
                              alt="LinkForge"
                              width="120"
                              class="logo-img"
                              style="display:block;margin:0 auto;"
                            />
                          </td>
                        </tr>
                      </table>
                      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:16px;">
                        <tr><td style="height:1px;background:rgba(255,255,255,0.15);"></td></tr>
                      </table>
                      <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td valign="middle" style="vertical-align:middle;">
                            <p style="margin:0 0 3px 0;font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.6);">Team Invitation</p>
                            <p style="margin:0;font-size:20px;font-weight:700;color:#ffffff;letter-spacing:-0.3px;" class="header-title">You're invited to LinkForge</p>
                          </td>
                          <td width="48" style="vertical-align:middle;padding-left:12px;white-space:nowrap;" valign="middle" align="right">
                            <div
                              style="width:40px;height:40px;background:rgba(255,255,255,0.18);border-radius:10px;text-align:center;line-height:40px;font-size:18px;"
                              class="icon-box"
                            >🎉</div>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- BODY -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="padding:28px 32px;" class="card-body">
                      <p style="margin:0 0 6px 0;font-size:20px;font-weight:700;color:#111827;" class="greeting">Hi there,</p>
                      <p style="margin:0 0 24px 0;font-size:15px;color:#6b7280;line-height:1.7;"><strong style="color:#111827;">{{invitedByName}}</strong> has invited you to join LinkForge as
                        <strong style="color:#111827;">{{role}}</strong>. Create your account to get started.</p>

                      <table cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px 0;">
                        <tr>
                          <td>
                            
                              href="{{signupLink}}"
                              style="display:inline-block;background:#7c3aed;color:#ffffff;text-decoration:none;padding:14px 32px;border-radius:10px;font-size:15px;font-weight:700;box-shadow:0 4px 14px rgba(124,58,237,0.3);"
                              class="cta-btn"
                            >Accept Invite & Sign Up →</a>
                          </td>
                        </tr>
                      </table>

                      <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td style="background:#f5f3ff;border-left:3px solid #7c3aed;border-radius:0 8px 8px 0;padding:13px 15px;" class="notice-box">
                            <p style="margin:0;font-size:14px;color:#374151;line-height:1.6;">
                              <strong style="color:#5b21b6;">Important:</strong>
                              Sign up using this exact email address to receive your <strong>{{role}}</strong> access automatically.
                            </p>
                          </td>
                        </tr>
                      </table>

                      <p style="margin:20px 0 0 0;font-size:13px;color:#9ca3af;line-height:1.6;">
                        If you weren't expecting this invitation, you can safely ignore this email.
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- FOOTER -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr><td style="padding:0 32px;"><div style="height:1px;background:#f3f4f6;"></div></td></tr>
                  <tr>
                    <td align="center" style="padding:16px 32px;" class="card-footer">
                      <p style="margin:0;font-size:12px;color:#9ca3af;">© 2026 LinkForge. All rights reserved.</p>
                    </td>
                  </tr>
                </table>

              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>