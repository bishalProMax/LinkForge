<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/pages/verification.css" />
    <link rel="icon" type="image/png" href="/images/icon.png" />

    <title>Email Verification</title>
  </head>

  <body>
    <div class="verification-container">
      <div class="verification-box">
        <div class="status-icon <%= success ? 'success' : 'error' %>"><%= success ? '✓' : '✕' %></div>
        <h1 class="<%= success ? 'success-text' : 'error-text' %>"><%= success ? 'Email Verified' : 'Verification Failed' %></h1>

        <% if (success) { %>
        <p class="verification-message">Your account has been successfully verified. You can now log in and start using LinkForge.</p>
        <a href="/login" class="verification-btn"> Go to Login </a>

        <% } else { %>
        <p class="verification-message">This verification link is invalid, expired, or has already been used.</p>
        <a href="/signup" class="verification-btn"> Create New Account </a>

        <% } %>
      </div>
    </div>
  </body>
</html>
