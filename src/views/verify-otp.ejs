<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/images/icon.png" />
    <link rel="stylesheet" href="/css/pages/auth.css" />
    <script type="module" src="/js/main.js" defer></script>

    <title>Verify OTP</title>
  </head>

  <body>
    <div class="auth-container auth-box">
      <h1 class="auth-title">Verify OTP</h1>

      <% if (error) { %>
      <p class="error"><%= error %></p>
      <% } %>

      <% if (message) { %>
      <p class="auth-message"><%= message %></p>
      <% } %>

      <form action="/user/verify-reset-otp" method="POST">
        <input type="hidden" name="email" value="<%= old.email %>" />
        <div class="otp-wrapper">
          <!-- Real OTP input for autofill -->
          <input type="text" id="otpHiddenInput" autocomplete="one-time-code" inputmode="numeric" maxlength="6" />
          <!-- Submitted to backend -->
          <input type="hidden" name="otp" id="otpValue" required />
          <div class="otp-boxes">
            <input type="text" maxlength="1" class="otp-digit" />
            <input type="text" maxlength="1" class="otp-digit" />
            <input type="text" maxlength="1" class="otp-digit" />
            <input type="text" maxlength="1" class="otp-digit" />
            <input type="text" maxlength="1" class="otp-digit" />
            <input type="text" maxlength="1" class="otp-digit" />
          </div>
        </div>
        <button type="submit" class="auth-btn">Verify OTP</button>
      </form>

      <!-- RESEND OTP -->
      <div class="resend-section" data-cooldown="<%= cooldown || 0 %>">
        <form action="/user/forgot-password" method="POST">
          <input type="hidden" name="email" value="<%= old.email %>" />
          <button type="submit" class="resend-btn" id="resendBtn" disabled>Resend OTP</button>
        </form>

        <p class="resend-timer" id="resendTimer"></p>
      </div>

      <div class="back-to-login">
        <a href="/login"> Back to Login </a>
      </div>
    </div>
  </body>
</html>
