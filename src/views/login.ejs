<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/images/icon.png" />
    <link rel="stylesheet" href="/css/pages/auth.css" />
    <script type="module" src="/js/main.js"></script>

    <title>Login</title>
  </head>

  <body>
    <div class="auth-container">
      <h1>Login</h1>

      <!-- Error Message -->
      <% if (error) { %>
      <p class="error"><%= error %></p>
      <% } %>

      <!-- Verification Message -->
      <% if (verificationMessage) { %>
      <p class="verification-info"><%= verificationMessage %></p>
      <% } %>

      <!-- Login Form -->
      <form action="/user/login" method="POST" autocomplete="on">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" autocomplete="username" required value="<%= old?.email || '' %>" />
        </div>

        <div class="form-group">
          <label>Password</label>
          <div class="password-wrapper">
            <input type="password" id="loginPassword" name="password" autocomplete="current-password" required />
            <button type="button" id="toggleLoginPassword">Show</button>
          </div>
          <p>
            <a href="/forgot-password"> Forgot Password? </a>
          </p>
        </div>

        <button type="submit">Login</button>
      </form>

      <div class="oauth-divider">
        <span>or continue with</span>
      </div>

      <div class="oauth-container">
        <a href="/auth/google" class="google-auth-btn">
          <img src="/images/google.svg" alt="Google" class="google-icon" />

          <span> Continue with Google </span>
        </a>
      </div>

      <!-- Signup Link -->
      <p class="auth-footer">
        Don't have an account?
        <a href="/signup"> Create Account </a>
      </p>
    </div>
  </body>
</html>
