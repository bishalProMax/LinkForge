<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="icon" type="image/png" href="/images/icon.png" />
    <script type="module" src="/js/main.js"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
  </head>
  <body>
    <div class="container">
      <h1>Login</h1>

      <!-- Error Message -->
      <% if (error) { %>
      <p class="error"><%= error %></p>
      <% } %>

      <!-- Verification Message -->
      <% if (verificationMessage) { %>
      <p class="verification-info"><%= verificationMessage %></p>
      <% } %>

      <!-- Login Form -->
      <form action="/user/login" method="POST" autocomplete="on">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" autocomplete="username" required value="<%= old?.email || '' %>" />
        </div>

        <div class="form-group">
          <label>Password</label>
          <div class="password-wrapper">
            <input type="password" id="loginPassword" name="password" autocomplete="current-password" required />
            <button type="button" id="toggleLoginPassword">Show</button>
          </div>
          <p>
            <a href="/forgot-password"> Forgot Password? </a>
          </p>
        </div>

        <button type="submit">Login</button>
      </form>

      <div class="oauth-divider">
        <span>or continue with</span>
      </div>

      <div class="oauth-container">
        <a href="/auth/google" class="google-auth-btn">
          <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google" class="google-icon" />

          <span> Google </span>
        </a>
      </div>

      <!-- Signup Link -->
      <p>
        Don't have an account?
        <a href="/signup"> Create Account </a>
      </p>
    </div>
  </body>
</html>
