<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css" rel="stylesheet">
    <style>
        .url-form {
            display: flex;
            gap: 10px;
            margin-top: 10px;
            align-items: center;
        }

        .url-form input {
            flex: 1;
        }
    </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomePage</title>
</head>
<body>

    <div class="container">

    <div class="header">
        
    <h1>Welcome to LinkForge</h1>

    <form action="/user/logout" method="POST" class="logout-form">
        <button type="submit" class="logout-btn">Logout</button>
    </form>
    </div>

        <!-- Form -->
    
        <form class="url-form" method="POST" action="/url/generate">
            <label >Enter your original URL</label>
            <input type="text" name="url" placeholder="https://example.com/my-long-url" required>
            <button type="submit">Generate</button>
        </form>
        
        <% if (error) { %>
            <p class="error"><%= error %></p>
        <% } %>


        <!-- Generated URL -->
    <% if (Id) { %>
        <div class="generated">
        URL Generated: 
            <a href="/url/<%= Id %>" target="_blank"><%= Id %>
            </a>
        </div>
        <% } %>



        <!-- URL List -->
    <div class="table-section">

    <% if (urls && urls.length > 0) { %>
        <h3>All URLs</h3>

    <table cellpadding="20" cellspacing="0">
        <thead> 
            <tr>
            <th> S. No.</th>  
            <th> ShortID</th>  
            <th> Redirect</th>  
            <th> Clicks</th>  
        </tr>
        </thead>
        <tbody>
            <% urls.forEach((url,index) => { %>
                <tr>
                <td><%= index + 1  %></td>
                <td class="shortid-cell">
                    <a href="/url/<%= url.shortId %>" target="_blank"> <%= url.shortId %> 
                    </a>
                    <button type="button" class="copy-btn" data-id="<%= url.shortId %>" onclick="copyToClipboard(this)" title="Copy short URL">
                        <i class="ri-file-copy-line"></i>
                    </button>
                </td>
                <td> 
                    <a href="<%= url.redirectURL %>" target="_blank" class="redirect-link"> <%= url.redirectURL %> 
                    </a> 
                </td>
                <td>
                    <%= url.visitHistory.length  %>
                </td>
                </tr>
                <% }) %>
        </tbody>
    </table>
    <% } %>
    </div>

</div>
    <script src="/js/main.js"></script>
</body>
</html>